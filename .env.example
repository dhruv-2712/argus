# ARGUS environment variables
# Copy this file to .env and fill in your keys.
# All keys are optional — layers degrade gracefully when keys are missing.

# Groq API key — required for SPECTER terrain analysis
# Get a free key at: https://console.groq.com
GROQ_API_KEY=

# ACLED API key — required for structured conflict event data
# Register for free academic access at: https://acleddata.com/register
ACLED_API_KEY=
ACLED_EMAIL=

# NASA FIRMS map key — required for the thermal anomaly layer
# Get a free key at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# Redis URL — optional, enables multi-worker WebSocket fan-out
# Leave blank for single-worker deployments (Render/Railway default)
REDIS_URL=

# OpenSky Network (flights layer) needs no key — anonymous access is used.

# Google Earth Engine project (only needed if SAR layer uses GEE fallback)
# Register at: https://earthengine.google.com
GEE_PROJECT=
