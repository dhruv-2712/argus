# ARGUS environment variables
# Copy this file to .env and fill in your keys.
# All keys are optional — layers degrade gracefully when keys are missing.

# Groq API key — required for SPECTER terrain analysis
# Get a free key at: https://console.groq.com
GROQ_API_KEY=

# ACLED API key — required for structured conflict event data
# Register for free academic access at: https://acleddata.com/register
ACLED_API_KEY=
ACLED_EMAIL=

# AISHub username — required for AIS maritime vessel tracking
# Register for free at: https://www.aishub.net/join-us
AISHUB_USERNAME=

# Google Earth Engine project (only needed if SAR layer uses GEE fallback)
# Register at: https://earthengine.google.com
GEE_PROJECT=
